NODE_ENV=development
PORT=3000

# Comma separated origins, example: http://localhost:3000,https://app.example.com
CORS_ORIGIN=http://localhost:3000
FORCE_HTTPS=false

JWT_ACCESS_SECRET=replace_with_minimum_32_characters_secret
JWT_REFRESH_SECRET=replace_with_minimum_32_characters_secret

# Throttling
THROTTLE_LIMIT=100
THROTTLE_TTL_MS=60000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opside

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin seed (required when running prisma/seed-admin.ts)
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ReplaceWithStrongPassword123
ADMIN_SEED_FIRST_NAME=Super
ADMIN_SEED_LAST_NAME=Admin
