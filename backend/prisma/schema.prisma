generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  candidat
  client
  admin
}

enum UserStatus {
  active
  suspended
  deleted
  pending
}

enum Speciality {
  frontend
  backend
  fullstack
  mobile
  devops
  data
  design
  other
}

enum Currency {
  MGA
  XOF
  XAF
  MAD
  TND
  KES
  NGN
  EGP
  MUR
  EUR
  USD
}

enum Country {
  kenya
  nigeria
  egypte
  maroc
  tunisie
  madagascar
  senegal
  maurice
}

enum Availability {
  immediate
  two_weeks
  one_month
  three_months
  unavailable
}

enum CandidateStatus {
  open_to_work
  in_mission
  part_time
}

// enum SkillCategory {
//   frontend
//   backend
//   mobile
//   devops
//   data
//   design
// }

enum EmploymentType {
  temps_plein
  temps_partiel
  freelance
  independant
  stage_alternance
  apprentissage
  stage
  alternance
}

enum EducationLevel {
  bac
  bac_plus_2
  bac_plus_3
  bac_plus_4
  bac_plus_5
  doctorat
  bac_plus_8
  autre
}

enum CompanySize {
  size_1_10
  size_11_50
  size_51_200
  size_200_plus
}

enum TestType {
  platform
  client
}

enum TestStatus {
  pending
  in_progress
  submitted
  scored
  expired
}

model User {
  id                       String     @id @default(uuid())
  email                    String     @unique
  password                 String
  role                     Role
  first_name               String?
  last_name                String?
  created_at               DateTime   @default(now())
  status                   UserStatus @default(active)
  email_verification_token String?
  reset_password_token   String?
  reset_password_expires DateTime?

  refresh_tokens RefreshToken[]
  candidate      CandidateProfile?
  client         ClientProfile?
  skills         Skill[]
  tests          Test[]
  job_offers     JobOffer[]

  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  user_id    String
  expires_at DateTime
  created_at DateTime @default(now())
  is_revoked Boolean  @default(false)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Skill {
  id        String   @id @default(uuid())
  name      String
  category  String
  is_custom Boolean  @default(false)
  owner_id  String?

  candidate_skills  CandidateSkill[]
  experience_skills ExperienceSkill[]
  education_skills  EducationSkill[]
  job_offer_skills  JobOfferSkill[]

  owner User? @relation(fields: [owner_id], references: [id], onDelete: Cascade)

  @@unique([name, owner_id])
  @@map("skills")
}

model CandidateProfile {
  id                 String           @id @default(uuid())
  user_id            String           @unique
  phone              String?
  country            Country
  city               String?
  bio                String?
  title              String?
  speciality         Speciality
  custom_speciality  String?
  experience_years   Int
  daily_rate         Decimal
  currency           Currency
  availability       Availability
  status             CandidateStatus  @default(open_to_work)
  linkedin_url       String?
  portfolio_url      String?
  github_url         String?
  photo_url          String?
  profile_completed  Boolean          @default(false)
  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  user               User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  candidate_skills   CandidateSkill[]
  experiences        Experience[]
  educations         Education[]

  @@map("candidate_profiles")
}

model CandidateSkill {
  candidate_id String
  skill_id     String

  candidate CandidateProfile @relation(fields: [candidate_id], references: [id], onDelete: Cascade)
  skill     Skill            @relation(fields: [skill_id], references: [id], onDelete: Cascade)

  @@id([candidate_id, skill_id])
  @@map("candidate_skills")
}

model Experience {
  id              String         @id @default(uuid())
  candidate_id    String
  title           String
  employment_type EmploymentType
  company         String
  start_month     Int
  start_year      Int
  end_month       Int?
  end_year        Int?
  is_current      Boolean        @default(false)
  location        String?
  description     String?
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  candidate         CandidateProfile  @relation(fields: [candidate_id], references: [id], onDelete: Cascade)
  experience_skills ExperienceSkill[]
  experience_medias ExperienceMedia[]

  @@map("experiences")
}

model ExperienceSkill {
  experience_id String
  skill_id      String

  experience Experience @relation(fields: [experience_id], references: [id], onDelete: Cascade)
  skill      Skill      @relation(fields: [skill_id], references: [id], onDelete: Cascade)

  @@id([experience_id, skill_id])
  @@map("experience_skills")
}

model ExperienceMedia {
  id            String   @id @default(uuid())
  experience_id String
  url           String
  media_type    String
  public_id     String?
  created_at    DateTime @default(now())

  experience Experience @relation(fields: [experience_id], references: [id], onDelete: Cascade)

  @@map("experience_medias")
}

model Education {
  id           String          @id @default(uuid())
  candidate_id String
  school       String
  degree       String?
  field        String?
  start_month  Int
  start_year   Int
  end_month    Int?
  end_year     Int?
  is_current   Boolean         @default(false)
  level        EducationLevel?
  custom_level String?
  description  String?
  created_at   DateTime        @default(now())
  updated_at   DateTime        @updatedAt

  candidate       CandidateProfile @relation(fields: [candidate_id], references: [id], onDelete: Cascade)
  education_skills EducationSkill[]
  education_medias EducationMedia[]

  @@map("educations")
}

model EducationSkill {
  education_id String
  skill_id     String

  education Education @relation(fields: [education_id], references: [id], onDelete: Cascade)
  skill     Skill     @relation(fields: [skill_id], references: [id], onDelete: Cascade)

  @@id([education_id, skill_id])
  @@map("education_skills")
}

model EducationMedia {
  id           String   @id @default(uuid())
  education_id String
  url          String
  media_type   String
  public_id    String?
  created_at   DateTime @default(now())

  education Education @relation(fields: [education_id], references: [id], onDelete: Cascade)

  @@map("education_medias")
}

model ClientProfile {
  id                     String      @id @default(uuid())
  user_id                String      @unique
  company_name           String
  company_size           CompanySize?
  industry               String?
  country                Country
  city                   String?
  contact_name           String
  contact_email          String
  contact_phone          String?
  website                String?
  logo_url               String?
  logo_public_id         String?
  interview_availability String?
  created_at             DateTime    @default(now())
  updated_at             DateTime    @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

model Test {
  id                    String     @id @default(uuid())
  candidate_id          String
  type                  TestType
  skills_tested         String[]   // Stocké comme array de strings (technos)
  speciality            String     // frontend | backend | fullstack | mobile | devops | data
  difficulty            String     // junior | mid | senior
  questions             Json       // Array de questions générées
  answers               Json?      // Réponses du candidat
  score                 Int?       // 0-100
  score_details         Json?      // Détail par question
  duration_minutes      Int
  started_at            DateTime?
  submitted_at          DateTime?
  status                TestStatus @default(pending)
  ai_model              String?    
  ai_generation_prompt  String?    
  ai_evaluation_prompt  String?    
  created_at            DateTime   @default(now())
  updated_at            DateTime   @updatedAt

  candidate             User       @relation(fields: [candidate_id], references: [id], onDelete: Cascade)

  @@map("tests")
}

model Video {
  id          String   @id @default(uuid())
  title       String
  description String?
  url         String
  public_id   String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("videos")
}

enum JobOfferStatus {
  draft
  active
  paused
  closed
}

enum WorkType {
  full_remote
  hybrid
  on_site
}

model JobOffer {
  id                  String     @id @default(uuid())
  client_id           String
  title               String
  description         String
  speciality          Speciality
  experience_min      Int?
  tjm_client          Decimal
  contract_duration   String?
  work_type           WorkType
  timezone_preference String?
  start_date          DateTime?
  status              JobOfferStatus @default(draft)
  is_anonymous        Boolean    @default(true)
  created_at          DateTime   @default(now())
  updated_at          DateTime   @updatedAt
  views_count         Int        @default(0)
  applications_count  Int        @default(0)

  client              User       @relation(fields: [client_id], references: [id], onDelete: Cascade)
  skills_required     JobOfferSkill[]

  @@map("job_offers")
}

model JobOfferSkill {
  job_offer_id String
  skill_id     String

  job_offer    JobOffer @relation(fields: [job_offer_id], references: [id], onDelete: Cascade)
  skill        Skill    @relation(fields: [skill_id], references: [id], onDelete: Cascade)

  @@id([job_offer_id, skill_id])
  @@map("job_offer_skills")
}